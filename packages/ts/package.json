{
  "name": "@arcanada/output-guard",
  "version": "0.1.5",
  "description": "Validate, repair, retry LLM structured output (JSON / YAML / TOML / Python literal) — 15-strategy two-pass repair chain with Zod adapter.",
  "license": "MIT",
  "author": "Arcanada <pavel@arcanada.one>",
  "homepage": "https://github.com/Arcanada-one/output-guard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcanada-one/output-guard.git",
    "directory": "packages/ts"
  },
  "bugs": {
    "url": "https://github.com/Arcanada-one/output-guard/issues"
  },
  "keywords": [
    "llm",
    "json",
    "yaml",
    "toml",
    "repair",
    "structured-output",
    "zod",
    "arcanada"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parity": "vitest run tests/parity",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "jsonrepair": "^3.14.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ajv": "^8.17.0",
    "fast-check": "^3.23.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
